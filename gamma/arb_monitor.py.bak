comps=[]
conn = pymysql.connect(host='localhost',user='local',passwd='oeijifjwejfio',db='arb_db')
cur  = conn.cursor()
cur.execute("select * from comps")
rows = cur.fetchall()
conn.close()
for row in rows:
    comps.append({"toto":str(row[4]),"betfair":str(row[2]),"league":row[1]})

print(comps[0])

def go():
    threads = min(len(comps),10)

    with concurrent.futures.ThreadPoolExecutor(max_workers=threads) as executor:
        executor.map(process_comp, comps )

while 1:
    go()
    time.sleep(30)#sleep 30secs before redownload
