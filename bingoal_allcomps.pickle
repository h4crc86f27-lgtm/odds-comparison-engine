		<script type="text/javascript" language="javascript">
			var util = (function(){
				//PROPERTIES
				var defaultStake=1,//DEFAULTSTAKE FOR A BET = MINSTAKE OR 1 IF MINSTAKE LOWER THAN 1
				minTotalStake = .5,
				maxTotalStake = 500,
				minStakePerBet=.1,
				maxStake = 500,
				t=parseInt('1'),//LANGUAGE AS NUMBER: 1=DUTCH, 2=FRENCH, 3=ENGLISH
				tc='nl';//LANGUAGE AS CODE: NL=DUTCH, FR=FRENCH, EN=ENGLISH

				var pubSub = {
				  events: {},
				  on: function (eventName, fn) {
				    this.events[eventName] = this.events[eventName] || [];
				    this.events[eventName].push(fn);
				  },
				  off: function(eventName, fn) {
				    if (this.events[eventName]) {
				      for (var i = 0; i < this.events[eventName].length; i++) {
				        if (this.events[eventName][i] === fn) {
				          this.events[eventName].splice(i, 1);
				          break;
				        }
				      };
				    }
				  },
				  emit: function (eventName, data) {
				    if (this.events[eventName]) {
				      this.events[eventName].forEach(function(fn) {
				        fn(data);
				      });
				    }
				  }
				};

				//FUNCTIONS

				function doRequest(params){
					//console.log("doRequest",params.url);
					//RETURN FALSE IF THERE'S NO URL DEFINED OR GLOBALS.CONNECTION.STOP IS TRUE AND PARAMS.TEST IS UNDEFINED
					if(isUnd(params.url)){return false;}
					return $.ajax({
						url : params.url,
						type : (params.type==null ? "POST" : params.type),
						data : params.data,
						contentType : (params.contentType==null ? "application/x-www-form-urlencoded; charset=UTF-8" : params.contentType),
						datatType:(params.dataType==null ? "json" : params.dataType),
						timeout : (params.timeout==null ? 5 * 1000 : params.timeout),
						success:function(response){
							if(!isUnd(params.callbackFunction)){params.callbackFunction();}
						},
						complete: function(xhr, textStatus, thrownError){
							//console.log("complete", xhr, textStatus, thrownError);
						}
					});
				}

				function formatOdd(odd, decimals, separator){
					separator = separator || ".";
					var val=parseFloat(odd).toFixed(decimals);
					return (separator=="." ? val : val.toString().replace(".", separator));
				}

				function euroToNumber(val){
					//remove euro-sign
					val=val.replace("&euro;","");
					//replace comma by dot
					val=val.replace(",",".");
					//remove blank space before & after
					val=val.trim();
					//converto to float
					val=parseFloat(val).toFixed(2);
					return val;
				}

				function numberToEuro(val,decimal,thousand){
					//check if val is not null or undefined
					if(val==null || val==="undefined"){val=0;}
					//remove blank space before & after
					val=val.toString().trim();
					//format to 2 decimals after zÃ©ro if decimal not false
					val=parseFloat(val).toFixed((isUnd(decimal) ? 2 : decimal));
					//replace comma by ","
					val=val.replace(".",",");
					//thousand
					if(thousand==true){
						//keep comma "," part appart
						var comma=(val.indexOf(",")!=-1 ? val.substr(val.indexOf(",")) : "");
						var beforeComma=(val.indexOf(",")!=-1 ? val.substr(0,val.indexOf(",")) : val);
						beforeComma = beforeComma.replace(new RegExp("^(\\d{" + (beforeComma.length%3?beforeComma.length%3:0) + "})(\\d{3})", "g"), "$1 $2").replace(/(\d{3})+?/gi, "<span class='thousand'>$1</span>").trim().replace(" <","<");
						val=beforeComma+comma;
					}
					//put euro-sign before/after
					val=(t==1 ? "&euro;\xa0"+val : val+"\xa0&euro;" );
					return val;
				}

				//returns single numbers with a leading zero
				function zero(num){
					var numke=parseInt(num);
					if(numke<10){
						numke="0"+numke;
						return numke;
					}
					else{return numke;}
				}

				//formats the date in
				// h = hh:mm
				// dm dd/mm
				// dmh = dd/mm hh:mm
				// dmh2 = wo 02 dec 20:00
				// dmyh = dd/mm/yyyy hh:mm
				// dmyhms
				// ds dd/mm
				// cache = yyyy-mm-dd
				// race = dd augustus yyyy hh:mm
				function formatDate(datum,format){
					var datum;
					if(typeof datum=="object"){
						datum=new Date(datum);
					}
					else{
						var a=datum.split(" "),
						d=a[0].split("-"),
						t=a[1].split(":");

						datum = new Date(d[0],(d[1]-1),d[2],t[0],t[1],t[2]);
					}
					if(format=="h"){
						return zero(parseInt(datum.getHours()))+":"+zero(datum.getMinutes());
					}
					else if(format=="dm"){
						return zero(datum.getDate())+"/"+zero((datum.getMonth()+1));
					}
					else if(format=="dmy"){
						return zero(datum.getDate())+"/"+zero((datum.getMonth()+1))+"/"+(datum.getFullYear()+"").substr(2,2);
					}
					else if(format=="dmh"){
						return zero(datum.getDate())+"/"+zero((datum.getMonth()+1))+" "+zero(parseInt(datum.getHours()))+":"+zero(datum.getMinutes());
					}
					else if(format=="dmh2"){
						return (days[datum.getDay()]).slice(0,2)+" "+zero(datum.getDate())+" "+(months[datum.getMonth()]).slice(0,3)+" &nbsp;&nbsp;"+zero(parseInt(datum.getHours()))+":"+zero(datum.getMinutes());
					}
					else if(format=="dmyh"){
						return zero(datum.getDate())+"/"+zero((datum.getMonth()+1))+"/"+(datum.getFullYear()+"").substr(2,2)+" "+zero(parseInt(datum.getHours()))+":"+zero(datum.getMinutes());
					}
					else if(format=="dmyhms"){
						return zero(datum.getDate())+"/"+zero((datum.getMonth()+1))+"/"+(datum.getFullYear()+"").substr(2,2)+" "+zero(parseInt(datum.getHours()))+":"+zero(datum.getMinutes())+":"+zero(datum.getSeconds());
					}
					else if(format=="cache"){
						return zero(datum.getFullYear())+"-"+zero((datum.getMonth()+1))+"-"+zero(datum.getDate()+"");
					}
					else if(format=="ds dd/mm"){
						return (days[datum.getDay()]).slice(0,2)+" "+zero(datum.getDate())+"/"+(datum.getMonth()+1);
					}
					else if(format=="ds dd ms"){
						return (days[datum.getDay()]).slice(0,2)+" "+zero(datum.getDate())+" "+months[datum.getMonth()];
					}
					else if(format=="race"){
						return zero(datum.getDate())+" "+(months[datum.getMonth()])+" "+datum.getFullYear()+" &nbsp;&nbsp;"+zero(parseInt(datum.getHours()))+":"+zero(datum.getMinutes());
					}
				}

				function getBetslipType(){
					var body=$("body");

					if (body.hasClass("pagspo")){
						return "sport";
					}
					else if (body.hasClass("paglive")){
						return "sport";
					}
					else if (body.hasClass("pagrace")){
						return "race";
					}
					else{
						return false;
					}
				}

				function isSportLive(val){
					if (isUnd(val)){
						val=getBetslipType();
					}
					return ["sport", "live"].indexOf(val)!=-1;
				}

				function isUnd(o){
					if(typeof o == "undefined"){
						return true;
					}
					else{
						return false;
					}
				}

				function getDefaultStake(){
					return defaultStake;
				}

				function getMinTotalStake(){
					return minTotalStake;
				}

				function getMaxTotalStake(){
					return maxTotalStake;
				}

				function getMaxStake(){
					return maxStake;
				}

				function getMinStakePerBet(){
					return minStakePerBet;
				}

				function getT(){
					return t;
				}

				function getTc(){
					return tc;
				}

				return{
					doRequest:doRequest,
					euroToNumber:euroToNumber,
					formatOdd:formatOdd,
					formatDate:formatDate,
					getBetslipType:getBetslipType,
					getDefaultStake:getDefaultStake,
					getMinTotalStake:getMinTotalStake,
					getMaxTotalStake:getMaxTotalStake,
					getMaxStake:getMaxStake,
					getMinStakePerBet:getMinStakePerBet,
					getT:getT,
					getTc:getTc,
					isSportLive:isSportLive,
					isUnd:isUnd,
					numberToEuro:numberToEuro,
					pubSub:pubSub,
					zero:zero
				}

			})()

			var _ie = (navigator.userAgent.indexOf('MSIE') > -1 || navigator.userAgent.indexOf('Trident') > -1),
			_svg = (_ie ? 'gif' : 'svg'),
